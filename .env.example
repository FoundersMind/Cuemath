# Copy this file to ".env" (same folder as manage.py) and fill in values.
# Do not commit .env — it contains secrets.

OPENAI_API_KEY=
# Optional — defaults to gpt-4o-mini
OPENAI_MODEL=gpt-4o-mini
# Optional — defaults to whisper-1
OPENAI_TRANSCRIBE_MODEL=whisper-1
# OpenAI Text-to-Speech (interviewer voice)
OPENAI_TTS_MODEL=tts-1
OPENAI_TTS_VOICE=nova
# Shorter model replies = less LLM + TTS wait (about voice-length turns)
OPENAI_INTERVIEW_MAX_TOKENS=320
# Set to 1 to run OpenAI Moderations API on each candidate turn (blocks flagged content)
OPENAI_MODERATION=0

# Candidate anti-spam (optional). Min seconds between real answers; max real answers per rolling 60s.
# INTERVIEW_CANDIDATE_MIN_MESSAGE_INTERVAL_SEC=1.0
# INTERVIEW_CANDIDATE_MAX_MESSAGES_PER_MINUTE=18
# Reject one turn longer than this many characters (paste / filibuster). Default 10000.
# INTERVIEW_MAX_CANDIDATE_TURN_CHARS=10000
# Above this length (chars), a small classifier may tell Riley to move on if the answer is already sufficient.
# INTERVIEW_LONG_REPLY_CHAR_THRESHOLD=360

# PostgreSQL (production). Omit to use SQLite for local dev.
# DATABASE_URL=postgresql://USER:PASS@localhost:5432/cuemath_screener

# Django
DJANGO_SECRET_KEY=change-me-in-production
DJANGO_DEBUG=1
# Local: 127.0.0.1,localhost — Railway: add your *.up.railway.app hostname(s), comma-separated
DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost
